  "dependencies": {
    "@supabase/supabase-js": "catalog:",
    "drizzle-orm": "^0.39.0",
    "postgres": "^3.4.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cct/config": "workspace:*",
    "@cct/integrations": "workspace:*",
    "@types/node": "^25.8.0",
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
