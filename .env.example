###############################################################################
# ConciergeTravel.fr — Environment variables (template)
# Copy to .env.local and fill in values for local development.
# Production values are managed in Vercel and GitHub Actions secrets.
# See docs/10-environment-variables.md for the authoritative reference.
###############################################################################

# -----------------------------------------------------------------------------
# Public site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="ConciergeTravel"
NEXT_PUBLIC_DEFAULT_LOCALE="fr"

# -----------------------------------------------------------------------------
# Supabase (PostgreSQL + Auth)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""        # server-only, never exposed
SUPABASE_DB_URL=""                  # postgres://... for migrations / Payload
SUPABASE_PROJECT_REF=""

# -----------------------------------------------------------------------------
# Upstash Redis (cache + rate limiting)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Algolia (search)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ALGOLIA_APP_ID=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""
ALGOLIA_ADMIN_API_KEY=""             # server-only
ALGOLIA_INDEX_PREFIX="dev_"

# -----------------------------------------------------------------------------
# Amadeus GDS (Self-Service: Hotels Search v3 + Hotel Booking + Payments)
# -----------------------------------------------------------------------------
AMADEUS_ENV="test"                   # 'test' | 'production'
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""
AMADEUS_PAYMENT_WEBHOOK_SECRET=""    # HMAC for /api/webhook/amadeus-payment

# -----------------------------------------------------------------------------
# Little Hotelier
# -----------------------------------------------------------------------------
LITTLE_HOTELIER_API_BASE="https://api.littlehotelier.com"
LITTLE_HOTELIER_API_KEY=""

# -----------------------------------------------------------------------------
# Makcorps (price comparator — primary)
# -----------------------------------------------------------------------------
MAKCORPS_API_BASE="https://api.makcorps.com"
MAKCORPS_API_KEY=""
MAKCORPS_DAILY_QUOTA="10000"

# -----------------------------------------------------------------------------
# Apify (price comparator fallback)
# -----------------------------------------------------------------------------
APIFY_API_TOKEN=""
APIFY_HOTEL_ACTOR_ID=""

# -----------------------------------------------------------------------------
# Google Places (reviews sync)
# -----------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=""

# -----------------------------------------------------------------------------
# Brevo (transactional emails)
# -----------------------------------------------------------------------------
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="reservations@conciergetravel.fr"
BREVO_SENDER_NAME="ConciergeTravel"
BREVO_INTERNAL_OPS_EMAIL="reservations@conciergetravel.fr"

# -----------------------------------------------------------------------------
# Sentry (errors + tracing)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""                 # CI source-map upload
SENTRY_ORG=""
SENTRY_PROJECT_WEB="cct-web"
SENTRY_PROJECT_ADMIN="cct-admin"
SENTRY_ENV="dev"                     # 'dev' | 'preview' | 'staging' | 'production'
SENTRY_RELEASE=""                    # set in CI to the git SHA

# -----------------------------------------------------------------------------
# Cloudinary (media)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""  # same as CLOUDINARY_CLOUD_NAME, exposed to client for <HotelImage>/<HotelGallery>
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""             # server-only

# -----------------------------------------------------------------------------
# Payload CMS (apps/admin)
# -----------------------------------------------------------------------------
PAYLOAD_SECRET=""                    # any long random string, server-only
PAYLOAD_PUBLIC_SERVER_URL="http://localhost:3001"

# -----------------------------------------------------------------------------
# Cron / internal API
# -----------------------------------------------------------------------------
CRON_SECRET=""                       # protects /api/cron/* endpoints
REVALIDATE_SECRET=""                 # used by Payload afterChange to call /api/revalidate

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
DATADOG_ENABLED="false"
LOYALTY_PREMIUM_BILLING_ENABLED="false"

# -----------------------------------------------------------------------------
# Editorial pilot (Sprint 1B — scripts/editorial-pilot)
# Used ONLY by the standalone editorial AI pipeline that generates premium hotel
# fiches via a 4-pass LLM workflow. NEVER read by apps/web or apps/admin.
# Provide at least one of OPENAI_API_KEY / ANTHROPIC_API_KEY.
# -----------------------------------------------------------------------------
EDITORIAL_PILOT_PROVIDER="openai"    # 'openai' | 'anthropic'
OPENAI_API_KEY=""                    # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=""                 # https://console.anthropic.com/settings/keys
EDITORIAL_PILOT_OPENAI_MODEL="gpt-4o-2024-11-20"
EDITORIAL_PILOT_ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"
